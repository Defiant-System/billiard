<MenuBar>
	<Menu name="Billiard">
		<Menu name="About Billiard" shell="win -a"/>
		<Menu type="divider"/>
		<Menu name="Quit Billiard" shell="win -c"/>
	</Menu>
	<Menu name="Game" for="game-view">
		<Menu name="New Game">
			<Menu name="Player vs AI" click="new-game" arg="1"/>
			<Menu name="Player vs Player" click="new-game" arg="2"/>
		</Menu>
		<Menu type="divider"/>
		<Menu name="Toggle Sound FX" click="toggle-sound-fx"/>
		<Menu name="Toggle Music" click="toggle-music"/>
		<Menu type="divider"/>
		<Menu name="Output PGN" click="output-pgn"/>
	</Menu>
	<Menu name="Help">
		<Menu name="Help" click="open-help"/>
		<Menu type="divider"/>
		<Menu name="License" shell="win -al"/>
	</Menu>
</MenuBar>